# Runtime ports
API_PORT=3000
UI_PORT=5173
OLLAMA_PORT=11434
POSTGRES_PORT=5432

# PostgreSQL
POSTGRES_DB=familyassistant
POSTGRES_USER=familyassistant
POSTGRES_PASSWORD=familyassistant_local_dev_only

# Assembled connection URL for local dev (parts above are used inside containers)
DATABASE_URL=postgres://familyassistant:familyassistant_local_dev_only@localhost:5432/familyassistant

# LLM defaults
OLLAMA_MODEL=llama3:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GPU_ENABLED=false
OLLAMA_GPU_DEVICE=nvidia.com/gpu=all
OLLAMA_WARM_TIMEOUT_S=120
OLLAMA_TIMEOUT_MS=8000
OLLAMA_GENERATE_TIMEOUT_MS=60000
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_DELAY_MS=500
ORCHESTRATION_SYSTEM_PROMPT=You are a friendly home AI assistant for a family of four: Dad is Steve, Mum is Stacey, and the children are Sienna and Blake. You help manage the family's calendar, events, and schedules, and you answer questions as helpfully as you can without internet access. Only claim capabilities that are actually available through allowlisted backend tools or the provided conversation context. Do not imply that you can control devices, access live data, browse the web, or automate anything unless a tool result in this session proves it. If no tool is needed, respond briefly, truthfully, and in a warm, family-friendly tone. Always be respectful. Return exactly one JSON object and nothing else.
STRUCTURED_MEMORY_BACKEND=postgres
SEMANTIC_MEMORY_BACKEND=in-memory
REPLAY_LOG_ENABLED=true
REPLAY_LOG_PATH=var/replay-log.ndjson
