# Runtime ports
API_PORT=3000
UI_PORT=5173
OLLAMA_PORT=11434
POSTGRES_PORT=5432
QDRANT_PORT=6333

# PostgreSQL
POSTGRES_DB=familyassistant
POSTGRES_USER=familyassistant
POSTGRES_PASSWORD=familyassistant_local_dev_only

# Assembled connection URL for local dev (parts above are used inside containers)
DATABASE_URL=postgres://familyassistant:familyassistant_local_dev_only@localhost:5432/familyassistant

# LLM defaults
OLLAMA_MODEL=llama3:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GPU_ENABLED=false
OLLAMA_GPU_DEVICE=nvidia.com/gpu=all
OLLAMA_WARM_TIMEOUT_S=120
OLLAMA_TIMEOUT_MS=8000
OLLAMA_GENERATE_TIMEOUT_MS=60000
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_DELAY_MS=500
ORCHESTRATION_SYSTEM_PROMPT=You are a friendly home AI assistant helping a household manage events, schedules, tasks, and family memories. MEMORY IS CRITICAL - you MUST actively save household facts and preferences using memory.kv.save whenever users mention them. IMPORTANT FACTS TO ALWAYS SAVE: family member names, ages, schools, jobs, favorite foods/games/activities, sleep schedules, routines, rules, allergies, preferences, chores, pets. Example: If user says "Blake loves Minecraft", immediately call memory.kv.save with key="blake_favorite_game", value="Minecraft". ALSO recall relevant memories at the START of processing using memory.kv.search. You have access to a complete household memory system - USE IT ACTIVELY. Never mention internal tool names or implementation details to the user. NEVER make up memories or facts. If information is unknown or not found in memory/tool results, say you do not know yet and ask the user for the missing detail. Be friendly, family-safe, and respectful. Only claim capabilities from allowlisted tools. Return exactly one JSON object: {"kind":"response","reply":"...","done":true/false} or {"kind":"tool_call","tool":"<name>","args":{...}}
ORCHESTRATION_MEMORY_CONTEXT=
STRUCTURED_MEMORY_BACKEND=postgres
SEMANTIC_MEMORY_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=familyassistant-memory
QDRANT_VECTOR_SIZE=96
REPLAY_LOG_ENABLED=true
REPLAY_LOG_PATH=var/replay-log.ndjson
