# Runtime ports
API_PORT=3000
UI_PORT=5173
OLLAMA_PORT=11435
POSTGRES_PORT=5433

# PostgreSQL
POSTGRES_DB=familyassistant
POSTGRES_USER=familyassistant
POSTGRES_PASSWORD=familyassistant_local_dev_only

# Assembled connection URL for local dev (parts above are used inside containers)
DATABASE_URL=postgres://familyassistant:familyassistant_local_dev_only@localhost:5433/familyassistant

# LLM defaults
OLLAMA_MODEL=llama3:8b
OLLAMA_BASE_URL=http://localhost:11435
OLLAMA_GPU_ENABLED=true
OLLAMA_GPU_DEVICE=nvidia.com/gpu=all
OLLAMA_WARM_TIMEOUT_S=120
OLLAMA_TIMEOUT_MS=8000
OLLAMA_GENERATE_TIMEOUT_MS=60000
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_DELAY_MS=500
ORCHESTRATION_SYSTEM_PROMPT=You are a friendly home AI assistant helping a household manage events and memories. Save user facts with memory.add, remove facts with memory.remove, and use event tools when event data is needed. Never mention internal tool names to users. Never invent facts. Return exactly one JSON object: {"kind":"response","reply":"...","done":true/false} or {"kind":"tool_call","tool":"<name>","args":{...}}
ORCHESTRATION_MEMORY_CONTEXT=Household members: Steve (dad), Stacey (mom), Sienna (child), Blake (child). Prioritize family calendar and schedule support.
STRUCTURED_MEMORY_BACKEND=postgres
REPLAY_LOG_ENABLED=true
REPLAY_LOG_PATH=var/replay-log.ndjson
